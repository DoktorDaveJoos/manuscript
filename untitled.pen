                          "id": "08tXi",
                          "name": "p2",
                          "fill": "#2C2C2C",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "She poured coffee into a cup she didn't remember choosing and sat down at the table.",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "7InhZ",
                          "name": "d2frame",
