                            0
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "y77OT",
                              "name": "d1text",
                              "fill": "#DC2626",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The house behind her was still — the kind of still that comes after something has been broken but no one has decided yet what to do about it.",
                              "lineHeight": 1.65,
                              "fontFamily": "Newsreader",
                              "fontSize": 15,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
