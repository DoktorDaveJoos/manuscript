                          "name": "p4",
                          "fill": "#2C2C2C",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "‘Couldn’t sleep.’",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
