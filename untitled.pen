                          "name": "p5",
                          "fill": "#2C2C2C",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "He came into the kitchen and stood near the counter,",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
