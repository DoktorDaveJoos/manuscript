                          "id": "TP5hd",
                          "name": "p3",
                          "fill": "#2C2C2C",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "‘You’re up early,’ Jonas said from the hallway.",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "9AY9i",
                          "name": "d3frame",
                          "width": "fill_container",
                          "fill": "#FEF2F2",
                          "cornerRadius": 3,
                          "padding": [
                            3,
                            0
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "JjRPf",
                              "name": "d3text",
                              "fill": "#DC2626",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "His voice was careful; the way it had been for weeks now — each word placed like a foot testing thin ice.",
                              "lineHeight": 1.65,
                              "fontFamily": "Newsreader",
                              "fontSize": 15,
                              "fontWeight": "normal"
                            }
                          ]
                        },
