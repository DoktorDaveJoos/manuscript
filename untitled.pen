                          "fill": "#2C2C2C",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The rain had stopped sometime before dawn, leaving the streets glazed and silent. Maren stood at the kitchen window, watching the last of the clouds pull apart like old cotton.",
                          "lineHeight": 1.65,
                          "fontFamily": "Newsreader",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "5GX6Y",
                          "name": "d1frame",
                          "width": "fill_container",
