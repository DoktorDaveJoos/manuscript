                            {
                              "type": "text",
                              "id": "pVy5h",
                              "name": "d2text",
                              "fill": "#DC2626",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The chair creaked. Outside, a bird started up and then stopped, as if it too had thought better of it.",
                              "lineHeight": 1.65,
                              "fontFamily": "Newsreader",
                              "fontSize": 15,
                              "fontWeight": "normal"
                            }
                          ]
                        },
