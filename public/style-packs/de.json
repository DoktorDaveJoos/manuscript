    "patterns": [
        {
            "id": "passive",
            "regex": "(?<![\\p{L}\\p{M}])(?:wurde|wurden|wird|werden|worden)\\s+(?:\\p{L}+\\s+)?ge\\p{L}+(?:t|en)(?![\\p{L}\\p{M}])"
        },
        {
            "id": "passive",
            "regex": "(?<![\\p{L}\\p{M}])ge\\p{L}+(?:t|en)\\s+(?:werden|wurde|wurden|wird|worden)(?![\\p{L}\\p{M}])"
        },
        {
            "id": "wuerde",
            "regex": "(?<![\\p{L}\\p{M}])würde(?:st|t|n)?(?![\\p{L}\\p{M}])"
        },
        {
            "id": "esGibt",
            "regex": "(?<![\\p{L}\\p{M}])es\\s+(?:gibt|gab)(?![\\p{L}\\p{M}])"
        }
    ],
