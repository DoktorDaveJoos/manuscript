    "patterns": [
        {
            "id": "sPassive",
            "regex": "(?<![\\p{L}\\p{M}])\\p{L}{3,}ades(?![\\p{L}\\p{M}])"
        },
        {
            "id": "blevPassive",
            "regex": "(?<![\\p{L}\\p{M}])(?:blev|blivit)\\s+\\p{L}+(?:ad|ade|at|en|et|na)(?![\\p{L}\\p{M}])"
        },
        {
            "id": "detFinns",
            "regex": "(?<![\\p{L}\\p{M}])det\\s+(?:finns|fanns)(?![\\p{L}\\p{M}])"
        }
